<UserControl x:Class="WPF_MVVM_SPA_Template.Views.Option1View"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_MVVM_SPA_Template.Views"
        mc:Ignorable="d" d:DesignWidth="500.375" d:DesignHeight="283.504">
    <Grid Background="White" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DataGrid ItemsSource="{Binding Clients}" 
                  SelectedItem="{Binding SelectedClient}" 
                  IsReadOnly="True"
                  AutoGenerateColumns="False" 
                  Grid.Row="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto" />
                <DataGridTextColumn Header="DNI" Binding="{Binding DNI}" Width="50" />
                <DataGridTextColumn Header="Nom" Binding="{Binding Name}" Width="Auto" />
                <DataGridTextColumn Header="Cognoms" Binding="{Binding last_name}" Width="*" />
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" />
                <DataGridTextColumn Header="Telèfon" Binding="{Binding Tlf}" Width="Auto" />
                <DataGridTextColumn Header="Data d'Alta" Binding="{Binding date}" Width="Auto" />
                <DataGridTextColumn Header="Accions" Binding="{Binding Id}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Botons i controls d'edició -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Afegir Client" Command="{Binding AddClientCommand}" Margin="5" Padding="10,5" 
                    Style="{StaticResource ModernPrimaryButtonStyle}"/>
            <Button Content="Eliminar" Command="{Binding DelClientCommand}" IsEnabled="{Binding SelectedClient}" 
                    Margin="5" Padding="10,5" Style="{StaticResource ModernSecundaryButtonStyle}"/>
            <Button Content="Veure Gràfica" Command="{Binding VeureGraficaCommand}" IsEnabled="{Binding SelectedClient}" 
                    Margin="5" Padding="10,5" Style="{StaticResource ModernThirdButtonStyle}"/>
        </StackPanel>
    </Grid>
</UserControl>
