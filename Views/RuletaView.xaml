<UserControl x:Class="WPF_MVVM_SPA_Template.Views.RuletaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F0F2F5">
        <Border Background="White" CornerRadius="15" Margin="40" Padding="30" MaxWidth="500" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Color="#D0D0D0" ShadowDepth="2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="🎰 RULETA DE PREMIS" FontSize="24" FontWeight="Bold" 
                           Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Text="Selecciona el client:" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding Main.Clients}" 
                          SelectedItem="{Binding ClientSeleccionat}">

                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding Email}" Foreground="Gray" FontStyle="Italic"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>

                </ComboBox>

                <Border Background="#2C3E50" CornerRadius="10" Padding="20" Margin="0,0,0,25">
                    <TextBlock Text="{Binding TextAnimatPremi}" Foreground="Gold" 
                               FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Border>

                <Button Content="GIRAR RULETA" Command="{Binding GirarCommand}" 
                        Height="55" Background="#27AE60" Foreground="White" 
                        FontSize="18" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>