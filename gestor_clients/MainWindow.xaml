<Window x:Class="Clients_Managment.MainWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        
        xmlns:viewmodels="clr-namespace:Clients_Managment.ViewModels"

        xmlns:views="clr-namespace:Clients_Managment.Views"

        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

        xmlns:local="clr-namespace:Clients_Managment"

        mc:Ignorable="d"

        Title="MainWindow" Height="450" Width="800">
    

        <DockPanel>

        <!-- Barra de navegació lateral estil SPA amb ListBox -->

        <ListBox DockPanel.Dock="Left" Width="107.895" Background="#2C3E50" Foreground="White" BorderThickness="0"

             SelectedValue="{Binding SelectedView, Mode=TwoWay}" SelectedValuePath="Tag">

            <ListBoxItem Content="Inici" Tag="Inici" FontSize="16" Padding="10" 

                         HorizontalContentAlignment="Left" Style="{StaticResource ModernSidebarStyle}"/>

            <ListBoxItem Content="Clients" Tag="Option1" FontSize="16" Padding="10" 

                         HorizontalContentAlignment="Left" Style="{StaticResource ModernSidebarStyle}"/>


            <ListBoxItem Content="Ruleta" Tag="Ruleta" FontSize="16" Padding="10"
                         HorizontalContentAlignment="Left" Style="{StaticResource ModernSidebarStyle}"/>

        </ListBox>

        <!-- Secció de contingut dinàmic (Grid) -->

        <Grid Name="MainContent" Background="White" Margin="10">

            <ContentControl Content="{Binding CurrentView}" />

        </Grid>

    </DockPanel>

</Window>